{
  "compilerOptions": {

    /* ============================================================
       CORE COMPILER SETTINGS
       ============================================================ */

    "target": "ES2020",
    "module": "commonjs",

    /* Critical: ensures proper Node module resolution */
    "moduleResolution": "node",

    /* Source and build output folders */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Compatibility */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Safety */
    "strict": false,

    /* IMPORTANT: prevents node_modules errors */
    "skipLibCheck": true,

    /* Allow build even with warnings */
    "noEmitOnError": false
  },

  /* ============================================================
     ONLY COMPILE YOUR SOURCE CODE
     ============================================================ */

  "include": [
    "src/**/*.ts"
  ],

  /* ============================================================
     CRITICAL FIX — DO NOT COMPILE node_modules
     ============================================================ */

  "exclude": [
    "node_modules",
    "dist"
  ]
}
